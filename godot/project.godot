; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Unilearn"
run/main_scene="res://app/splash/SplashScreen.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/stretch_mode=4

[audio]

buses/default_bus_layout=""
driver/mix_rate=16000

[autoload]

SpaceBackground="*res://app/shared/SpaceBackground.tscn"
FirebaseAuth="*res://services/firebase/firebase_auth.gd"
FirebaseDatabase="*uid://ciym8l8himec1"
AIState="*res://app/ai/ai_state.gd"
UnilearnSFX="*uid://bbbg67shrr6od"
UnilearnUserSettings="*uid://jq0h5f3i2d0o"
PlanetCardsCache="*uid://t3gcyd5dludt"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/ApolloSpeech/plugin.cfg", "res://addons/GodotGoogleSignIn/plugin.cfg", "res://addons/UnilearnLib/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
